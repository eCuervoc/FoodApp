<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#FFF8F2">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="14dp"
            android:paddingBottom="10dp"
            android:background="#FFFFFF">

            <Button
                android:id="@+id/btnOpenMenu"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="☰"
                android:textSize="22sp"
                android:contentDescription="Abrir menú lateral" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="10dp">

                <TextView
                    android:id="@+id/tvToolbarTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="FoodApp Pedidos"
                    android:textStyle="bold"
                    android:textColor="#3E2723"
                    android:textSize="20sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Comida rápida, carrito y pedidos"
                    android:textColor="#8D6E63"
                    android:textSize="12sp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnHomeTop"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="🏠"
                android:textSize="18sp"
                android:contentDescription="Volver al inicio" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/fragmentContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="6dp"
            android:background="#FFFFFF"
            android:elevation="8dp">

            <Button
                android:id="@+id/btnProducts"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="🏠\nInicio"
                android:textSize="11sp" />

            <Button
                android:id="@+id/btnCart"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="🛒\nCarrito"
                android:textSize="11sp" />

            <Button
                android:id="@+id/btnOrders"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="📦\nPedidos"
                android:textSize="11sp" />

            <Button
                android:id="@+id/btnProfile"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="👤\nPerfil"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/drawerMenu"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:padding="18dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🍔 FoodApp"
            android:textColor="#E64A19"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Menú lateral de navegación"
            android:textColor="#6D4C41"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="20dp" />

        <Button
            android:id="@+id/menuInicio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🏠  Volver al menú inicial" />

        <Button
            android:id="@+id/menuProductos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🍟  Ver comidas rápidas"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/menuCarrito"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🛒  Revisar carrito"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/menuPedidos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📦  Historial de pedidos"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/menuPerfil"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="👤  Mi perfil"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="bottom"
            android:text="Tip: usa el menú inferior para moverte rápido y el menú lateral para volver al inicio."
            android:textColor="#8D6E63"
            android:textSize="13sp" />
    </LinearLayout>
</androidx.drawerlayout.widget.DrawerLayout>
